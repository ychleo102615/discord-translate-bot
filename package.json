  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch index.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp -r src/locales dist/src/locales",
    "start": "node dist/index.js",
    "deploy": "tsx deploy-commands.ts",
    "test": "vitest run",
